# DBCheck 环境配置示例
# 复制此文件为 .env 并填写实际值
# 注意：.env 文件不要提交到代码仓库！

# ══════════════════════════════════════════════════════════════
# REST API 密钥（用于 CI/CD 等外部调用）
# ══════════════════════════════════════════════════════════════
DBCheck_API_KEY=your-secret-api-key-change-me

# ══════════════════════════════════════════════════════════════
# 邮件通知配置（SMTP）
# ══════════════════════════════════════════════════════════════
SMTP_HOST=smtp.qq.com
SMTP_PORT=587
SMTP_USER=your_email@qq.com
SMTP_PASSWORD=your_auth_code
SMTP_USE_TLS=true
SMTP_FROM_NAME=DBCheck 巡检报告

# ══════════════════════════════════════════════════════════════
# Webhook 通知配置
# ══════════════════════════════════════════════════════════════
# 企业微信 Webhook
WEBHOOK_URL=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=YOUR_KEY
WEBHOOK_TYPE=wecom

# 钉钉 Webhook
# WEBHOOK_URL=https://oapi.dingtalk.com/robot/send?access_token=YOUR_TOKEN
# WEBHOOK_TYPE=dingtalk
