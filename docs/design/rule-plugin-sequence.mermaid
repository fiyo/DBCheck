%% 9.1 启动加载（类型感知，修复报错）
sequenceDiagram
    participant Boot as web_ui 启动
    participant PC as plugin_core.load_plugins
    participant PL as plugin_loader.load_enabled_plugins
    participant Reg as PluginRegistry
    participant RE as RuleEngine
    Boot->>PC: load_plugins(plugins/enabled)
    loop 每个 enabled 目录
        PC->>PC: 读 plugin.json → detect_plugin_type
        alt type == rule
            PC->>PC: import entry(__init__.py)
            PC->>Reg: register(InspectionPlugin 实例)
            opt 含 rules/*.yaml
                PC->>RE: load_plugin_rules(dir) + reload
            end
        else type == inspection
            PC->>PC: import main_file(*Inspector)
            PC->>Reg: register(若也用 plugin_core)
        end
    end
    Boot->>PL: load_enabled_plugins()  (旧 web_ui 任务配置路径)
    PL->>PL: 仅处理 inspection；rule 类型直接跳过/委托

%% 9.2 启用规则插件
sequenceDiagram
    participant U as 用户/API
    participant PM as PluginManager.enable_plugin
    participant FS as shutil(copy)
    participant PC as plugin_core.load_plugin
    participant Reg as PluginRegistry
    participant RE as RuleEngine
    U->>PM: enable_plugin("dbcheck-charset-audit")
    PM->>FS: copytree(available → enabled)
    PM->>PM: detect_plugin_type(meta) == RULE
    PM->>PM: 跳过 _init_plugin_data（模板/基线）
    PM->>PC: load_plugin(enabled_dir)
    PC->>PC: import __init__.py → register(CharsetChecker())
    PC->>Reg: register_inspection(instance)
    opt 含 rules/*.yaml
        PM->>RE: load_plugin_rules(enabled_dir) + reload
    end
    PM-->>U: 已启用（规则已注册）

%% 9.3 卸载规则插件
sequenceDiagram
    participant U as 用户/API
    participant PM as PluginManager.disable_plugin
    participant Reg as PluginRegistry
    participant RE as RuleEngine
    participant FS as shutil
    U->>PM: disable_plugin("dbcheck-charset-audit")
    PM->>PM: detect_plugin_type(meta) == RULE
    PM->>Reg: unregister("dbcheck-charset-audit")
    opt 含 rules/*.yaml
        PM->>RE: unload_plugin_rules("dbcheck-charset-audit") + reload
    end
    PM->>PM: 跳过模板/基线清理（无）
    PM->>FS: rmtree(enabled_dir)
    PM-->>U: 已禁用

%% 9.4 启用巡检插件（对照，行为不变）
sequenceDiagram
    participant U as 用户/API
    participant PM as PluginManager.enable_plugin
    participant FS as shutil(copy)
    participant DAL as inspection_dal
    participant PC as plugin_core.load_plugin
    U->>PM: enable_plugin("oracle_jdbc")
    PM->>FS: copytree(available → enabled)
    PM->>PM: detect_plugin_type == INSPECTION
    PM->>DAL: _init_plugin_templates(sql_templates.json→模板)
    PM->>DAL: _init_plugin_baselines(baselines.json→基线)
    PM->>PC: load_plugin(enabled_dir) → register
    PM-->>U: 已启用（模板+基线已初始化）
