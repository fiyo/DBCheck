        """
        return self.run_inspection(*args, **kwargs)


def getData(*args, **kwargs):
    """
    兼容旧接口的全局函数
    供 web_ui.py 动态导入调用
    """
    inspector = MongodbInspector(kwargs.get('config', {}))
    return inspector.getData(*args, **kwargs)
